    {"type": "function", "function": {"name": "file_read", "description": "Read a file's content.", "parameters": {"type": "object", "properties": {"file_path": {"type": "string"}, "start_line": {"type": "integer"}, "end_line": {"type": "integer"}}, "required": ["file_path"]}}},
