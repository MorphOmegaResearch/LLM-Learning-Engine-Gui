{
  "name": "JSON Calls (Comprehensive)",
  "tools": [
    {"type": "function", "function": {"name": "file_search", "description": "Search files by pattern within a path.", "parameters": {"type": "object", "properties": {"pattern": {"type": "string"}, "path": {"type": "string", "default": "."}, "case_sensitive": {"type": "boolean", "default": false}, "max_results": {"type": "integer", "default": 100}}, "required": ["pattern"]}}},
