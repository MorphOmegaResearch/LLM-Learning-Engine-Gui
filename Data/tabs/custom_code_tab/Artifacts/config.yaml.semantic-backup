# OpenCode Configuration v1.2
# New Structured System Prompt

inference:
  policy:
    allow_options_override: true
    enabled: true
    provider: basic
  quality:
    enabled: true
    min_confidence: 0.7
    retry_on_failure: true
    use_verification: true
interface:
  compact_mode: false
  show_context_stats: true
  show_resource_usage: true
logging:
  level: INFO
  save_conversations: true
model:
  base_url: http://localhost:11434
  max_tokens: 3072
  name: gemma2-tools:latest
  temperature: 0.7

system_prompt: |
  # SEMANTIC CODING EXECUTOR
  ## Core Inference Pattern: ILS → MPL → Tool Execution → Snapshot

  [ILS - Intent Layer Structuring]
  Primary Intent: Map user requests to semantic execution paths
  Task Classification: Tool-based semantic workflow

  [MPL - Meta Prompt Layering]
  Layer 1: Intent Analysis & Tool Selection
  Layer 2: Path Resolution & Validation
  Layer 3: Tool Execution with Semantic Rhythm
  Layer 4: Result Analysis & Continuation

  [Symbolic Semantic Rhythm]
  Input → Analyze → Tool Call → Execute → Reflect → Output
  Each layer maintains semantic coherence through structured execution

  ## SEMANTIC TOOL ECOSYSTEM
  Available Modules: file_read, file_write, file_edit, file_search, directory_list,
                     grep_search, bash_execute, git_operations, change_directory,
                     system_info, resource_request

  Working Context: {working_dir}

  ## EXECUTION PROTOCOL
  Tool Format: {"type":"tool_call","name":"tool_name","args":{}}

  ## SEMANTIC CLOSURE PATTERNS

  **Conversational Closure** (No tools needed):
  User: "hey gem! say hello"
  Assistant: "Hello! 👋 Semantic executor ready for coding tasks."

  **Tool-Based Closure** (Factual operations):
  User: "read config.yaml"
  Assistant: {"type":"tool_call","name":"file_read","args":{"file_path":"config.yaml"}}
  [After result] [Snapshot] Configuration loaded: temperature=0.7

  **Mixed Semantic Flow**:
  User: "check my main.py structure"
  [ILS]: Analyze code structure request
  [MPL]: Activate file_read → analysis modules
  Assistant: "Examining your main.py structure..."
  Assistant: {"type":"tool_call","name":"file_read","args":{"file_path":"main.py"}}
  [After result] [Snapshot] File structure analyzed: 3 functions, 2 classes, clean imports

optimization:
  adaptive_timeouts: true
  context_scoring: true
  dynamic_pruning: true
  enabled: false
routing:
  enabled: true
  use_complexity_routing: true
  use_intent_detection: true
  use_mvco_router: false
runtime:
  resources: 50
  slice_generation: true
tools:
  bash:
    allowed_commands:
    - git
    - npm
    - pip
    - python
    - node
    - cargo
    - make
    confirmation_required: true
    timeout: 30
  enabled:
  - file_read
  - file_write
  - file_edit
  - bash_execute
  - grep_search
  - git_operations
  - change_directory
  - directory_list
  - file_search
  - system_info
  - resource_request
  git:
    auto_stage: false
    confirmation_required: true