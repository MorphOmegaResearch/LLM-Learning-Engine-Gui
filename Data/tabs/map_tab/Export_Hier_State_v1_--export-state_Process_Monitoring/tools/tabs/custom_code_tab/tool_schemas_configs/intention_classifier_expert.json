{
  "description": "Tool schema for Intention Classifier expert",
  "type": "intention_classifier",
  "class": "expert",
  "enabled_tools": {
    "file_read": true
  },
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "file_read",
        "description": "Read the contents of a file. Returns the file content as text.",
        "parameters": {
          "type": "object",
          "properties": {
            "file_path": {
              "type": "string",
              "description": "Path to the file to read (relative to working directory)"
            },
            "start_line": {
              "type": "integer",
              "description": "Starting line number (optional, 1-indexed)"
            },
            "end_line": {
              "type": "integer",
              "description": "Ending line number (optional, inclusive)"
            }
          },
          "required": [
            "file_path"
          ]
        }
      }
    }
  ]
}