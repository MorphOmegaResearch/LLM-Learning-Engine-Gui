class OnboarderGUI:
    """GUI interface for the onboarder."""
    
    def __init__(self, onboarding_manager: OnboardingManager):
        self.manager = onboarding_manager
        self.root = None
        self.tree = None
        self.current_tools = []
        
    def run(self):
        """Run the GUI."""
        self.root = tk.Tk()
        self.root.title("Tool Onboarder & Organizer")
        self.root.geometry("1200x800")
        
        # Setup menu
        menubar = tk.Menu(self.root)
        self.root.config(menu=menubar)
        
        # File menu
        file_menu = tk.Menu(menubar, tearoff=0)
        menubar.add_cascade(label="File", menu=file_menu)
        file_menu.add_command(label="New Session", command=self.new_session)
        file_menu.add_command(label="Load Session", command=self.load_session)
        file_menu.add_command(label="Save Session", command=self.save_session)
        file_menu.add_separator()
        file_menu.add_command(label="Exit", command=self.root.quit)
        
        # Tools menu
        tools_menu = tk.Menu(menubar, tearoff=0)
        menubar.add_cascade(label="Tools", menu=tools_menu)
        tools_menu.add_command(label="Discover Tools", command=self.discover_tools)
        tools_menu.add_command(label="Consolidate Tools", command=self.consolidate_tools)
        tools_menu.add_command(label="Launch Consolidated Menu", command=self.launch_menu)
        tools_menu.add_separator()
        tools_menu.add_command(label="Run Pathfixer", command=self.run_pathfixer)
        
        # View menu
        view_menu = tk.Menu(menubar, tearoff=0)
        menubar.add_cascade(label="View", menu=view_menu)
        view_menu.add_command(label="Refresh", command=self.refresh_view)
        view_menu.add_command(label="Show Log", command=self.show_log)
        
        # Setup main interface
        self.setup_main_interface()
        
        # Start with discovery
        self.discover_tools()
        
        self.root.mainloop()
    
    def setup_main_interface(self):
        """Setup the main GUI interface."""
        # Create paned window
        paned = ttk.PanedWindow(self.root, orient=tk.HORIZONTAL)
        paned.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        # Left panel - tool list
        left_frame = ttk.Frame(paned)
        paned.add(left_frame, weight=1)
        
        # Tool list header
        ttk.Label(left_frame, text="Discovered Tools", font=("Arial", 12, "bold")).pack(pady=5)
        
        # Tool list treeview
        tree_frame = ttk.Frame(left_frame)
        tree_frame.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        self.tree = ttk.Treeview(tree_frame, columns=("category", "status", "type"), show="tree headings")
        
        # Setup columns
        self.tree.heading("#0", text="Tool")
        self.tree.heading("category", text="Category")
        self.tree.heading("status", text="Status")
        self.tree.heading("type", text="Type")
        
        self.tree.column("#0", width=200)
        self.tree.column("category", width=100)
        self.tree.column("status", width=80)
        self.tree.column("type", width=80)
        
        # Scrollbar
        scrollbar = ttk.Scrollbar(tree_frame, orient=tk.VERTICAL, command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)
        
        self.tree.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        
        # Bind double-click
        self.tree.bind("<Double-Button-1>", self.on_tool_double_click)
        
        # Right panel - tool details
        right_frame = ttk.Frame(paned)
        paned.add(right_frame, weight=2)
        
        # Tool details notebook
        notebook = ttk.Notebook(right_frame)
        notebook.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        # Overview tab
        overview_frame = ttk.Frame(notebook)
        notebook.add(overview_frame, text="Overview")
        
        self.overview_text = scrolledtext.ScrolledText(overview_frame, wrap=tk.WORD, height=20)
        self.overview_text.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        self.overview_text.config(state=tk.DISABLED)
        
        # Details tab
        details_frame = ttk.Frame(notebook)
        notebook.add(details_frame, text="Details")
        
        self.details_text = scrolledtext.ScrolledText(details_frame, wrap=tk.WORD, height=20)
        self.details_text.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        self.details_text.config(state=tk.DISABLED)
        
        # Commands tab
        commands_frame = ttk.Frame(notebook)
        notebook.add(commands_frame, text="Commands")
        
        self.commands_text = scrolledtext.ScrolledText(commands_frame, wrap=tk.WORD, height=20)
        self.commands_text.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        self.commands_text.config(state=tk.DISABLED)
        
        # Status bar
        self.status_bar = ttk.Frame(self.root)
        self.status_bar.pack(fill=tk.X, padx=5, pady=2)
        
        self.status_label = ttk.Label(self.status_bar, text="Ready")
        self.status_label.pack(side=tk.LEFT)
    
    def update_status(self, message: str):
        """Update status bar."""
        self.status_label.config(text=message)
        self.root.update()
    
    def new_session(self):
        """Create a new session."""
        self.manager.create_session()
        self.update_status("New session created")
        self.refresh_view()
    
    def load_session(self):
        """Load an existing session."""
        # In a full implementation, would show a dialog
        self.update_status("Load session - not implemented")
    
    def save_session(self):
        """Save current session."""
        self.manager.save_current_session()
        self.update_status("Session saved")
    
    def discover_tools(self):
        """Discover tools."""
        self.update_status("Discovering tools...")
        
        # Clear tree
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        # Run discovery
        tools = self.manager.discover_and_onboard()
        self.current_tools = tools
        
        # Populate tree
        categories = {}
        for tool in tools:
            category = tool.category.value
            if category not in categories:
                categories[category] = self.tree.insert("", "end", text=category.title(), open=True)
            
            # Determine status icon
            status = "✓" if tool.has_argparse or tool.has_tkinter else "○"
            tool_type = "CLI" if tool.has_argparse else ("GUI" if tool.has_tkinter else "Unknown")
            
            item = self.tree.insert(categories[category], "end", 
                                   text=tool.name,
                                   values=(tool.category.value, status, tool_type))
            
            # Store tool reference
            self.tree.set(item, "tool", tool)
        
        self.update_status(f"Discovered {len(tools)} tools")
    
    def consolidate_tools(self):
        """Consolidate tools into menu."""
        self.update_status("Consolidating tools...")
        
        menu = self.manager.consolidate_tools()
        if menu:
            messagebox.showinfo("Success", 
                              f"Consolidated {len(menu.tools)} tools into menu.\n\n"
                              f"Menu saved to: org_tools/consolidated_menu.json\n"
                              f"Launcher: org_tools/launcher.py")
            self.update_status(f"Consolidated {len(menu.tools)} tools")
        else:
            messagebox.showerror("Error", "No tools to consolidate")
    
    def launch_menu(self):
        """Launch the consolidated menu."""
        launcher_path = self.manager.base_dir / "org_tools" / "launcher.py"
        
        if launcher_path.exists():
            try:
                subprocess.Popen([sys.executable, str(launcher_path), "--gui"])
                self.update_status("Launched consolidated menu")
            except Exception as e:
                messagebox.showerror("Error", f"Failed to launch menu: {e}")
        else:
            messagebox.showwarning("Not Found", "Launcher not found. Consolidate tools first.")
    
    def run_pathfixer(self):
        """Run pathfixer on tools."""
        self.update_status("Running pathfixer...")
        
        if self.manager.pathfixer_integration.find_pathfixer():
            fixes = self.manager.pathfixer_integration.consolidate_paths(
                self.current_tools, self.manager.current_session
            )
            
            if fixes:
                messagebox.showinfo("Pathfixer Results", 
                                  f"Applied {len(fixes)} path fixes")
                self.update_status(f"Applied {len(fixes)} path fixes")
            else:
                messagebox.showinfo("Pathfixer Results", "No path issues found")
                self.update_status("No path issues found")
        else:
            messagebox.showwarning("Pathfixer Not Found", 
                                 "Pathfixer not found. Skipping path consolidation.")
            self.update_status("Pathfixer not found")
    
    def refresh_view(self):
        """Refresh the view."""
        self.discover_tools()
    
    def show_log(self):
        """Show session log."""
        if self.manager.current_session and self.manager.current_session.log:
            log_window = tk.Toplevel(self.root)
            log_window.title("Session Log")
            log_window.geometry("800x600")
            
            log_text = scrolledtext.ScrolledText(log_window, wrap=tk.WORD)
            log_text.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
            
            for entry in self.manager.current_session.log:
                timestamp = entry.get('timestamp', '')
                action = entry.get('action', '')
                log_text.insert(tk.END, f"{timestamp}: {action}\n")
            
            log_text.config(state=tk.DISABLED)
        else:
            messagebox.showinfo("Log", "No log entries")
    
    def on_tool_double_click(self, event):
        """Handle tool double-click."""
        item = self.tree.selection()[0]
        tool = self.tree.set(item, "tool")
        
        if tool:
            self.show_tool_details(tool)
    
    def show_tool_details(self, tool: ToolMetadata):
        """Show details for a tool."""
        # Update overview
        self.overview_text.config(state=tk.NORMAL)
        self.overview_text.delete(1.0, tk.END)
        
        overview = f"""
Tool: {tool.name}
Category: {tool.category.value}
Path: {tool.file_path}
Description: {tool.description}

Has argparse: {tool.has_argparse}
Has tkinter: {tool.has_tkinter}

Dependencies: {', '.join(tool.dependencies) if tool.dependencies else 'None'}
Emitters: {', '.join(tool.emitters) if tool.emitters else 'None'}
Tags: {', '.join(tool.tags)}
"""
        self.overview_text.insert(1.0, overview)
        self.overview_text.config(state=tk.DISABLED)
        
        # Update details
        self.details_text.config(state=tk.NORMAL)
        self.details_text.delete(1.0, tk.END)
        
        details = f"""
File: {tool.file_path}
Discovered: {tool.discovered_at}
Tool ID: {tool.tool_id}

Arguments:
"""
        if tool.main_command:
            details += f"  Main command: {tool.main_command.name}\n"
            details += f"  Help: {tool.main_command.help_text}\n"
            
            if tool.main_command.arguments:
                details += "  Arguments:\n"
                for arg in tool.main_command.arguments:
                    details += f"    - {arg.name}: {arg.help_text}\n"
        
        if tool.subcommands:
            details += f"\n  Subcommands: {len(tool.subcommands)}\n"
            for sub in tool.subcommands[:3]:  # Show first 3
                details += f"    - {sub.name}: {sub.help_text}\n"
            if len(tool.subcommands) > 3:
                details += f"    ... and {len(tool.subcommands) - 3} more\n"
        
        if tool.usage_examples:
            details += "\nUsage Examples:\n"
            for example in tool.usage_examples:
                details += f"  {example}\n"
        
        self.details_text.insert(1.0, details)
        self.details_text.config(state=tk.DISABLED)
        
        # Update commands
        self.commands_text.config(state=tk.NORMAL)
        self.commands_text.delete(1.0, tk.END)
        
        commands = f"""
Command to run this tool:
  python {tool.file_path.name} --help

Quick commands:
"""
        # Generate example commands
        if tool.has_argparse:
            if tool.subcommands:
                # Use first subcommand
                sub = tool.subcommands[0]
                commands += f"  python {tool.file_path.name} {sub.name}\n"
            elif tool.global_arguments:
                # Show with first optional argument
                for arg in tool.global_arguments:
                    if arg.arg_type == ArgParseType.OPTIONAL:
                        commands += f"  python {tool.file_path.name} {arg.name} VALUE\n"
                        break
        
        commands += f"""
Consolidated menu command:
  python org_tools/launcher.py --tool tool_{tool.tool_id}
"""
        self.commands_text.insert(1.0, commands)
        self.commands_text.config(state=tk.DISABLED)


# =============================================================================
# COMMAND LINE INTERFACE
# =============================================================================

def main():
    """Main CLI entry point."""
    parser = argparse.ArgumentParser(
        description="Tool Onboarder & Organization System",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Discover tools and create consolidated menu
  onboarder.py discover --consolidate
  
  # Discover tools recursively with path fixing
  onboarder.py discover --recursive --fix-paths
  
  # Launch GUI interface
  onboarder.py gui
  
  # List discovered tools
  onboarder.py list
  
  # Get tool information
  onboarder.py info --tool TOOL_ID
  
  # Run consolidated menu
  onboarder.py run-menu
  
  # Check for path issues
  onboarder.py check-paths

Workflows:
  1. Discovery: onboarder.py discover --recursive
  2. Consolidation: onboarder.py consolidate --name "My Tools"
  3. Launch: onboarder.py run-menu --gui
  4. Maintenance: onboarder.py check-paths --fix

Session Management:
  - Sessions are auto-saved in .onboarding_sessions/
  - Use --session to specify a session
  - Use --new-session to start fresh
        """
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Command to execute')
    
    # Discover command
    discover_parser = subparsers.add_parser('discover', help='Discover tools')
    discover_parser.add_argument('--recursive', '-r', action='store_true', 
                               help='Recursive discovery')
    discover_parser.add_argument('--depth', '-d', type=int, default=3,
                               help='Maximum recursion depth (default: 3)')
    discover_parser.add_argument('--fix-paths', '-f', action='store_true',
                               help='Fix path issues using pathfixer')
    discover_parser.add_argument('--consolidate', '-c', action='store_true',
                               help='Consolidate after discovery')
    discover_parser.add_argument('--session', '-s', help='Session ID')
    discover_parser.add_argument('--new-session', action='store_true',
                               help='Start new session')
    discover_parser.add_argument('--detailed', action='store_true',
                               help='Show detailed output')

    # Consolidate command
    consolidate_parser = subparsers.add_parser('consolidate', help='Consolidate tools')
    consolidate_parser.add_argument('--name', '-n', default="Org Tools",
                                  help='Menu name (default: "Org Tools")')
    consolidate_parser.add_argument('--session', '-s', help='Session ID')
    
    # GUI command
    gui_parser = subparsers.add_parser('gui', help='Launch GUI')
    gui_parser.add_argument('--session', '-s', help='Session ID')
    
    # List command
    list_parser = subparsers.add_parser('list', help='List tools')
    list_parser.add_argument('--session', '-s', help='Session ID')
    list_parser.add_argument('--detailed', '-d', action='store_true',
                           help='Detailed output')
    list_parser.add_argument('--category', '-c', help='Filter by category')
    
    # Info command
    info_parser = subparsers.add_parser('info', help='Get tool information')
    info_parser.add_argument('--tool', '-t', required=True, help='Tool ID or name')
    info_parser.add_argument('--session', '-s', help='Session ID')
    
    # Run menu command
    run_parser = subparsers.add_parser('run-menu', help='Run consolidated menu')
    run_parser.add_argument('--gui', '-g', action='store_true', help='Launch GUI')
    run_parser.add_argument('--tool', '-t', help='Run specific tool')
    run_parser.add_argument('--list', '-l', action='store_true', help='List tools')
    
    # Check paths command
    check_parser = subparsers.add_parser('check-paths', help='Check for path issues')
    check_parser.add_argument('--fix', '-f', action='store_true', help='Fix issues')
    check_parser.add_argument('--session', '-s', help='Session ID')
    
    # Session command
    session_parser = subparsers.add_parser('session', help='Session management')
    session_parser.add_argument('--list', '-l', action='store_true', help='List sessions')
    session_parser.add_argument('--info', '-i', help='Session ID to show')
    session_parser.add_argument('--delete', '-d', help='Session ID to delete')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return
    
    # Initialize onboarding manager
    manager = OnboardingManager()
    
    # Handle session
    if hasattr(args, 'session') and args.session:
        session = manager.load_session(args.session)
        if not session:
            print(f"Session not found: {args.session}")
            return
    elif hasattr(args, 'new_session') and args.new_session:
        manager.create_session()
    elif manager.current_session is None:
        # Create default session
        manager.create_session()
    
    # Execute command
    if args.command == 'discover':
        handle_discover(args, manager)
    elif args.command == 'consolidate':
        handle_consolidate(args, manager)
    elif args.command == 'gui':
        handle_gui(args, manager)
    elif args.command == 'list':
        handle_list(args, manager)
    elif args.command == 'info':
        handle_info(args, manager)
    elif args.command == 'run-menu':
        handle_run_menu(args, manager)
    elif args.command == 'check-paths':
        handle_check_paths(args, manager)
    elif args.command == 'session':
        handle_session(args, manager)

def handle_discover(args, manager: OnboardingManager):
    """Handle discover command."""
    print(f"\n{'='*60}")
    print("TOOL DISCOVERY")
    print(f"{'='*60}")
    
    print(f"Mode: {'Recursive' if args.recursive else 'Current directory only'}")
    if args.recursive:
        print(f"Depth: {args.depth}")
    print(f"Fix paths: {'Yes' if args.fix_paths else 'No'}")
    
    # Discover tools
    tools = manager.discover_and_onboard(
        recursive=args.recursive,
        max_depth=args.depth,
        fix_paths=args.fix_paths
    )
    
    print(f"\nDiscovered {len(tools)} tools:")
    
    # Group by category
    categories = {}
    for tool in tools:
        category = tool.category.value
        if category not in categories:
            categories[category] = []
        categories[category].append(tool)
    
    for category, cat_tools in categories.items():
        print(f"\n{category.upper()} ({len(cat_tools)}):")
        for tool in cat_tools:
            type_icon = "🖥️" if tool.has_argparse else ("🖼️" if tool.has_tkinter else "📄")
            print(f"  {type_icon} {tool.name}")
            if args.detailed:
                print(f"     {tool.description[:80]}...")
                if tool.dependencies:
                    print(f"     Dependencies: {', '.join(tool.dependencies[:3])}")
    
    # Consolidate if requested
    if args.consolidate:
        print(f"\n{'='*60}")
        print("CONSOLIDATING TOOLS")
        print(f"{'='*60}")
        
        menu = manager.consolidate_tools()
        if menu:
            print(f"Created consolidated menu with {len(menu.tools)} items")
            print(f"Menu saved to: org_tools/consolidated_menu.json")
            print(f"Launcher: org_tools/launcher.py")
            print(f"\nTo run: python org_tools/launcher.py --list")
    
    print(f"\nSession: {manager.current_session.session_id}")
    print(f"{'='*60}")

def handle_consolidate(args, manager: OnboardingManager):
    """Handle consolidate command."""
    print(f"\n{'='*60}")
    print(f"TOOL CONSOLIDATION: {args.name}")
    print(f"{'='*60}")
    
    menu = manager.consolidate_tools(args.name)
    
    if menu:
        print(f"Successfully consolidated {len(menu.tools)} tools")
        print(f"\nCategories:")
        for category in menu.categories:
            print(f"  {category['display_name']}: {category['count']} tools")
        
        print(f"\nTop tools:")
        for tool in sorted(menu.tools, key=lambda x: x.order)[:10]:
            shortcut = f" [{tool.shortcut}]" if tool.shortcut else ""
            print(f"  {tool.order:2}. {tool.display_name}{shortcut}")
        
        print(f"\nFiles created:")
        print(f"  org_tools/consolidated_menu.json")
        print(f"  org_tools/launcher.py")
        
        print(f"\nUsage:")
        print(f"  List tools: python org_tools/launcher.py --list")
        print(f"  Launch GUI: python org_tools/launcher.py --gui")
        print(f"  Run tool: python org_tools/launcher.py --tool TOOL_ID")
    
    else:
        print("No tools to consolidate. Run discovery first.")
    
    print(f"{'='*60}")

def handle_gui(args, manager: OnboardingManager):
    """Handle GUI command."""
    print("Launching GUI...")
    gui = OnboarderGUI(manager)
    gui.run()

def handle_list(args, manager: OnboardingManager):
    """Handle list command."""
    if not manager.current_session or not manager.current_session.onboarded_tools:
        print("No tools found. Run discovery first.")
        return
    
    tools = manager.current_session.onboarded_tools
    
    # Filter by category if specified
    if args.category:
        tools = [t for t in tools if t.category.value == args.category]
        if not tools:
            print(f"No tools found in category: {args.category}")
            return
    
    print(f"\n{'='*60}")
    print(f"TOOLS LIST ({len(tools)} total)")
    print(f"{'='*60}")
    
    if args.detailed:
        for i, tool in enumerate(tools, 1):
            print(f"\n{i:3}. {tool.name}")
            print(f"     ID: {tool.tool_id}")
            print(f"     Category: {tool.category.value}")
            print(f"     Path: {tool.file_path}")
            print(f"     Description: {tool.description}")
            print(f"     Type: {'CLI' if tool.has_argparse else 'GUI' if tool.has_tkinter else 'Unknown'}")
            print(f"     Dependencies: {', '.join(tool.dependencies) if tool.dependencies else 'None'}")
            print(f"     Emitters: {', '.join(tool.emitters) if tool.emitters else 'None'}")
            print(f"     Tags: {', '.join(tool.tags)}")
            
            if tool.usage_examples:
                print(f"     Examples:")
                for example in tool.usage_examples[:2]:
                    print(f"       - {example}")
    else:
        # Simple list
        for i, tool in enumerate(tools, 1):
            type_icon = "🖥️" if tool.has_argparse else ("🖼️" if tool.has_tkinter else "📄")
            print(f"{i:3}. {type_icon} {tool.name} ({tool.category.value})")
            print(f"     {tool.description[:80]}...")
    
    print(f"\nUse 'onboarder.py info --tool TOOL_ID' for detailed information")
    print(f"{'='*60}")

def handle_info(args, manager: OnboardingManager):
    """Handle info command."""
    if not manager.current_session or not manager.current_session.onboarded_tools:
        print("No tools found.")
        return
    
    # Find tool
    tool = None
    for t in manager.current_session.onboarded_tools:
        if t.tool_id == args.tool or t.name.lower() == args.tool.lower():
            tool = t
            break
    
    if not tool:
        print(f"Tool not found: {args.tool}")
        return
    
    print(f"\n{'='*60}")
    print(f"TOOL INFORMATION: {tool.name}")
    print(f"{'='*60}")
    
    print(f"\nBasic Information:")
    print(f"  Name: {tool.name}")
    print(f"  ID: {tool.tool_id}")
    print(f"  Category: {tool.category.value}")
    print(f"  File: {tool.file_path}")
    print(f"  Discovered: {tool.discovered_at}")
    
    print(f"\nDescription:")
    print(f"  {tool.description}")
    
    print(f"\nCapabilities:")
    print(f"  Has argparse (CLI): {tool.has_argparse}")
    print(f"  Has tkinter (GUI): {tool.has_tkinter}")
    
    print(f"\nMetadata:")
    print(f"  Dependencies: {', '.join(tool.dependencies) if tool.dependencies else 'None'}")
    print(f"  Emitters: {', '.join(tool.emitters) if tool.emitters else 'None'}")
    print(f"  Tags: {', '.join(tool.tags)}")
    
    if tool.usage_examples:
        print(f"\nUsage Examples:")
        for example in tool.usage_examples:
            print(f"  {example}")
    
    if tool.has_argparse and tool.main_command:
        print(f"\nCLI Interface:")
        print(f"  Main command: {tool.main_command.name}")
        print(f"  Help: {tool.main_command.help_text}")
        
        if tool.main_command.arguments:
            print(f"  Arguments:")
            for arg in tool.main_command.arguments:
                required = " (required)" if arg.required else ""
                print(f"    - {arg.name}: {arg.help_text}{required}")
        
        if tool.subcommands:
            print(f"  Subcommands ({len(tool.subcommands)}):")
            for sub in tool.subcommands[:5]:  # Show first 5
                print(f"    - {sub.name}: {sub.help_text}")
            if len(tool.subcommands) > 5:
                print(f"    ... and {len(tool.subcommands) - 5} more")
    
    print(f"\nCommands to run:")
    print(f"  Direct: python {tool.file_path.name} --help")
    print(f"  Via launcher: python org_tools/launcher.py --tool {tool.tool_id}")
    
    print(f"\n{'='*60}")

def handle_run_menu(args, manager: OnboardingManager):
    """Handle run-menu command."""
    launcher_path = manager.base_dir / "org_tools" / "launcher.py"
    
    if not launcher_path.exists():
        print("Consolidated menu not found. Run consolidation first.")
        return
    
    # Build command
    cmd = [sys.executable, str(launcher_path)]
    
    if args.gui:
        cmd.append("--gui")
    elif args.tool:
        cmd.extend(["--tool", args.tool])
    elif args.list:
        cmd.append("--list")
    else:
        cmd.append("--list")  # Default to list
    
    print(f"Running: {' '.join(cmd)}")
    
    try:
        subprocess.run(cmd)
    except Exception as e:
        print(f"Error running launcher: {e}")

def handle_check_paths(args, manager: OnboardingManager):
    """Handle check-paths command."""
    if not manager.current_session or not manager.current_session.onboarded_tools:
        print("No tools found. Run discovery first.")
        return
    
    tools = manager.current_session.onboarded_tools
    
    print(f"\n{'='*60}")
    print("PATH ISSUES CHECK")
    print(f"{'='*60}")
    
    # Check for pathfixer
    integrator = PathFixerIntegrator(manager.base_dir / "org_tools")
    if not integrator.find_pathfixer():
        print("Pathfixer not found. Skipping path checks.")
        return
    
    # Scan tools
    issues_found = 0
    for tool in tools:
        issues = integrator._scan_tool_for_path_issues(tool)
        if issues:
            issues_found += len(issues)
            print(f"\n{tool.name}: {len(issues)} issues")
            for issue in issues[:3]:  # Show first 3
                print(f"  Line {issue['line']}: {issue['issue']}")
                print(f"    {issue['content'][:80]}...")
    
    if issues_found == 0:
        print("\nNo path issues found.")
    else:
        print(f"\nTotal issues found: {issues_found}")
        
        if args.fix:
            print("\nApplying fixes...")
            fixes = integrator.consolidate_paths(tools, manager.current_session)
            print(f"Applied {len(fixes)} fixes")
    
    print(f"{'='*60}")

def handle_session(args, manager: OnboardingManager):
    """Handle session command."""
    sessions_dir = manager.base_dir / ".onboarding_sessions"
    
    if args.list:
        # List all sessions
        sessions = []
        for session_file in sessions_dir.glob("*.json"):
            try:
                with open(session_file, 'r') as f:
                    session_data = json.load(f)
                
                sessions.append({
                    "id": session_file.stem,
                    "created": session_data.get('created_at', ''),
                    "tools": len(session_data.get('onboarded_tools', [])),
                    "consolidated": len(session_data.get('consolidated_tools', []))
                })
            except:
                continue
        
        if not sessions:
            print("No sessions found.")
            return
        
        print(f"\n{'='*60}")
        print("SESSIONS")
        print(f"{'='*60}")
        
        for session in sorted(sessions, key=lambda x: x["created"], reverse=True):
            print(f"\n{session['id']}")
            print(f"  Created: {session['created']}")
            print(f"  Tools: {session['tools']}")
            print(f"  Consolidated: {session['consolidated']}")
        
        print(f"\n{'='*60}")
    
    elif args.info:
        # Show session info
        session = manager.load_session(args.info)
        if not session:
            print(f"Session not found: {args.info}")
            return
        
        print(f"\n{'='*60}")
        print(f"SESSION: {session.session_id}")
        print(f"{'='*60}")
        
        print(f"Created: {session.created_at}")
        print(f"Tools directory: {session.tools_dir}")
        print(f"Tools discovered: {len(session.onboarded_tools)}")
        print(f"Tools consolidated: {len(session.consolidated_tools)}")
        print(f"Fixes applied: {len(session.fixes_applied)}")
        print(f"Current step: {session.current_step}")
        
        if session.issues_found:
            print(f"\nIssues found: {len(session.issues_found)}")
            for issue in session.issues_found[:5]:
                print(f"  - {issue.get('type', 'unknown')}: {issue.get('description', '')[:80]}...")
        
        print(f"\n{'='*60}")
    
    elif args.delete:
        # Delete session
        session_file = sessions_dir / f"{args.delete}.json"
        if session_file.exists():
            session_file.unlink()
            print(f"Deleted session: {args.delete}")
        else:
            print(f"Session not found: {args.delete}")

if __name__ == "__main__":
    main()
