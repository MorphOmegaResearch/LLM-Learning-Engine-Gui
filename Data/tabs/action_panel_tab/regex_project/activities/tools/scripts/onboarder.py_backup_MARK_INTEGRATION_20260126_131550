# =============================================================================
# PATHFIXER INTEGRATION
# =============================================================================

class PathFixerIntegrator:
    """Integrates with pathfixer for path consolidation."""
    
    def __init__(self, tools_dir: Path):
        self.tools_dir = tools_dir
        self.pathfixer_path = None
        
    def find_pathfixer(self) -> Optional[Path]:
        """Find pathfixer in the directory tree."""
        # Check in current directory
        possible_paths = [
            self.tools_dir.parent / "pathfixer.py",
            Path.cwd() / "pathfixer.py",
            Path(__file__).parent / "pathfixer.py",
            Path.home() / "pathfixer.py",
        ]
        
        for path in possible_paths:
            if path.exists():
                self.pathfixer_path = path
                logger.info(f"[EVENT] Found pathfixer at {path}")
                return path
        
        logger.warning("[EVENT] Pathfixer not found")
        return None
    
    def consolidate_paths(self, tools: List[ToolMetadata], 
                         session: OnboardingSession) -> List[Dict[str, Any]]:
        """Consolidate paths using pathfixer (if available)."""
        if not self.find_pathfixer():
            return []
        
        fixes_applied = []
        
        for tool in tools:
            # Check if tool has path issues
            issues = self._scan_tool_for_path_issues(tool)
            
            if issues:
                # Apply fixes using pathfixer
                fix_result = self._apply_pathfixer_fixes(tool, issues, session)
                if fix_result:
                    fixes_applied.append(fix_result)
                    logger.info(f"[EVENT] Applied path fixes to {tool.name}")
        
        return fixes_applied
    
    def _scan_tool_for_path_issues(self, tool: ToolMetadata) -> List[Dict[str, Any]]:
        """Scan a tool for path-related issues."""
        issues = []
        
        try:
            content = tool.file_path.read_text(encoding='utf-8')
            
            # Check for hardcoded paths
            hardcoded_patterns = [
                r'["\']/home/[^"\']+["\']',
                r'["\']/usr/[^"\']+["\']',
                r'["\']C:\\[^"\']+["\']',
                r'["\']D:\\[^"\']+["\']',
                r'["\'][A-Z]:\\\\[^"\']+["\']',
            ]
            
            lines = content.split('\n')
            for i, line in enumerate(lines, 1):
                for pattern in hardcoded_patterns:
                    if re.search(pattern, line):
                        issues.append({
                            "file": str(tool.file_path),
                            "line": i,
                            "issue": "hardcoded_path",
                            "content": line.strip(),
                            "pattern": pattern
                        })
            
            # Check for relative paths that might break
            relative_patterns = [
                r'["\']\.\.[\\/][^"\']+["\']',
                r'["\']\.[\\/][^"\']+["\']',
            ]
            
            for i, line in enumerate(lines, 1):
                for pattern in relative_patterns:
                    if re.search(pattern, line):
                        issues.append({
                            "file": str(tool.file_path),
                            "line": i,
                            "issue": "relative_path",
                            "content": line.strip(),
                            "pattern": pattern
                        })
        
        except Exception as e:
            logger.error(f"[EVENT] Failed to scan {tool.file_path} for path issues: {e}")
        
        return issues
    
    def _apply_pathfixer_fixes(self, tool: ToolMetadata, issues: List[Dict[str, Any]],
                              session: OnboardingSession) -> Optional[Dict[str, Any]]:
        """Apply pathfixer fixes to a tool."""
        if not self.pathfixer_path:
            return None
        
        try:
            # Run pathfixer scan on the tool
            result = subprocess.run(
                [sys.executable, str(self.pathfixer_path), "scan", str(tool.file_path)],
                capture_output=True,
                text=True,
                cwd=tool.file_path.parent
            )
            
            fix_result = {
                "tool_id": tool.tool_id,
                "tool_name": tool.name,
                "scan_output": result.stdout,
                "issues_found": len(issues),
                "timestamp": datetime.datetime.now().isoformat(),
                "success": result.returncode == 0
            }
            
            # Log to session
            session.log.append({
                "timestamp": datetime.datetime.now().isoformat(),
                "action": "pathfixer_scan",
                "tool": tool.name,
                "issues": len(issues),
                "output": result.stdout[:500]  # Limit log size
            })
            
            return fix_result
            
        except Exception as e:
            logger.error(f"[EVENT] Failed to run pathfixer on {tool.file_path}: {e}")
            return None


# =============================================================================
# ONBOARDING SESSION MANAGER
# =============================================================================

class OnboardingManager:
    """Manages tool onboarding sessions."""
    
    def __init__(self, base_dir: Path = None):
        self.base_dir = base_dir or Path.cwd()
        self.sessions_dir = self.base_dir / ".onboarding_sessions"
        self.sessions_dir.mkdir(exist_ok=True)
        
        self.current_session = None
        self.discoverer = ToolDiscoverer(self.base_dir)
        self.consolidator = ToolConsolidator(self.base_dir / "org_tools")
        self.pathfixer_integration = PathFixerIntegrator(self.base_dir / "org_tools")
        
    def create_session(self, session_name: str = None) -> OnboardingSession:
        """Create a new onboarding session."""
        if not session_name:
            session_name = f"session_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}"
        
        session = OnboardingSession(
            session_id=session_name,
            created_at=datetime.datetime.now().isoformat(),
            tools_dir=self.base_dir / "org_tools"
        )
        
        self.current_session = session
        self._save_session(session)
        
        logger.info(f"[EVENT] Created onboarding session: {session.session_id}")
        return session
    
    def load_session(self, session_id: str) -> Optional[OnboardingSession]:
        """Load an existing session."""
        session_file = self.sessions_dir / f"{session_id}.json"
        
        if not session_file.exists():
            return None
        
        try:
            with open(session_file, 'r', encoding='utf-8') as f:
                session_data = json.load(f)
            
            # Convert paths
            session_data['tools_dir'] = Path(session_data['tools_dir'])
            
            # Convert tool metadata if present
            if 'onboarded_tools' in session_data:
                tools = []
                for tool_data in session_data['onboarded_tools']:
                    tool_data['file_path'] = Path(tool_data['file_path'])
                    # Convert category string back to enum
                    tool_data['category'] = ToolCategory(tool_data['category'])
                    tools.append(ToolMetadata(**tool_data))
                session_data['onboarded_tools'] = tools
            
            session = OnboardingSession(**session_data)
            self.current_session = session
            
            logger.info(f"[EVENT] Loaded session: {session.session_id}")
            return session
            
        except Exception as e:
            logger.error(f"[EVENT] Failed to load session {session_id}: {e}")
            return None
    
    def save_current_session(self):
        """Save the current session."""
        if self.current_session:
            self._save_session(self.current_session)
    
    def _save_session(self, session: OnboardingSession):
        """Save a session to disk."""
        session_data = asdict(session)
        
        # Convert Path objects to strings
        session_data['tools_dir'] = str(session.tools_dir)
        
        # Convert tool metadata
        if session.onboarded_tools:
            tool_data = []
            for tool in session.onboarded_tools:
                tool_dict = asdict(tool)
                tool_dict['file_path'] = str(tool.file_path)
                tool_dict['category'] = tool.category.value
                tool_data.append(tool_dict)
            session_data['onboarded_tools'] = tool_data
        
        session_file = self.sessions_dir / f"{session.session_id}.json"
        
        with open(session_file, 'w', encoding='utf-8') as f:
            json.dump(session_data, f, indent=2, default=str)
        
        logger.debug(f"[EVENT] Session saved: {session_file}")
    
    def discover_and_onboard(self, recursive: bool = True, 
                            max_depth: int = 3, 
                            fix_paths: bool = True) -> List[ToolMetadata]:
        """Discover and onboard tools."""
        if not self.current_session:
            self.create_session()
        
        session = self.current_session
        
        logger.info(f"[EVENT] Starting tool discovery (recursive: {recursive}, depth: {max_depth})")
        
        # Discover tools
        tools = self.discoverer.discover_tools(recursive, max_depth)
        
        # Fix paths if requested and pathfixer available
        if fix_paths:
            logger.info("[EVENT] Running pathfixer integration")
            fixes = self.pathfixer_integration.consolidate_paths(tools, session)
            session.fixes_applied.extend(fixes)
        
        # Update session
        session.onboarded_tools = tools
        session.current_step = 1
        self.save_current_session()
        
        logger.info(f"[EVENT] Discovered {len(tools)} tools")
        return tools
    
    def consolidate_tools(self, menu_name: str = "Org Tools") -> ConsolidatedToolMenu:
        """Consolidate discovered tools into a menu."""
        if not self.current_session or not self.current_session.onboarded_tools:
            logger.warning("[EVENT] No tools to consolidate. Run discovery first.")
            return None
        
        session = self.current_session
        
        logger.info(f"[EVENT] Consolidating {len(session.onboarded_tools)} tools")
        
        # Consolidate tools
        menu = self.consolidator.consolidate_tools(session.onboarded_tools, menu_name)
        
        # Update session
        session.consolidated_tools = [tool.tool_id for tool in session.onboarded_tools]
        session.current_step = 2
        self.save_current_session()
        
        logger.info(f"[EVENT] Created consolidated menu with {len(menu.tools)} items")
        return menu


