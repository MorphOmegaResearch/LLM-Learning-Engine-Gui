"""
Tool Onboarder & Organization System
====================================
Non-invasive tool organization with right-click menu, treeview, and co-op nesting.
Consolidates argparse tools into unified interface with pathfixer integration.
"""

import os
import sys
import json
import argparse
import subprocess
import shutil
import hashlib
import datetime
import tempfile
import threading
import re
from pathlib import Path
from typing import Dict, List, Set, Tuple, Any, Optional, Union
from dataclasses import dataclass, field, asdict
from enum import Enum
import tkinter as tk
from tkinter import ttk, filedialog, messagebox, scrolledtext
import ast

# #[EVENT] Setup logging
import logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler(f"/tmp/onboarder_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)


# =============================================================================
# DATA STRUCTURES
# =============================================================================

class ToolCategory(Enum):
    ANALYZER = "analyzer"
    ORGANIZER = "organizer"
    PATHFIXER = "pathfixer"
    IMPORT_ORG = "import_organizer"
    UTILITY = "utility"
    CUSTOM = "custom"


class ArgParseType(Enum):
    POSITIONAL = "positional"
    OPTIONAL = "optional"
    FLAG = "flag"
    SUBPARSER = "subparser"


@dataclass
class ArgParseArgument:
    """Extracted argparse argument information."""
    name: str
    arg_type: ArgParseType
    help_text: str = ""
    default: Any = None
    choices: List[str] = field(default_factory=list)
    required: bool = False
    nargs: Optional[str] = None
    metavar: str = ""
    dest: str = ""
    action: str = "store"


@dataclass
class ArgParseCommand:
    """Extracted argparse command (subparser)."""
    name: str
    help_text: str = ""
    arguments: List[ArgParseArgument] = field(default_factory=list)


@dataclass
class ToolMetadata:
    """Metadata for a discovered tool."""
    tool_id: str
    name: str
    file_path: Path
    category: ToolCategory
    description: str = ""
    version: str = "1.0.0"
    has_argparse: bool = False
    has_tkinter: bool = False
    main_command: Optional[ArgParseCommand] = None
    subcommands: List[ArgParseCommand] = field(default_factory=list)
    global_arguments: List[ArgParseArgument] = field(default_factory=list)
    dependencies: List[str] = field(default_factory=list)
    usage_examples: List[str] = field(default_factory=list)
    discovered_at: str = field(default_factory=lambda: datetime.datetime.now().isoformat())
    last_used: Optional[str] = None
    use_count: int = 0
    efficiency_score: float = 0.0
    priority: int = 100  # Lower = higher priority
    tags: List[str] = field(default_factory=list)
    emitters: List[str] = field(default_factory=list)  # Data fields this tool emits


@dataclass
class OnboardingSession:
    """Session for tool onboarding."""
    session_id: str
    created_at: str
    tools_dir: Path
    onboarded_tools: List[ToolMetadata] = field(default_factory=list)
    consolidated_tools: List[str] = field(default_factory=list)
    issues_found: List[Dict[str, Any]] = field(default_factory=list)
    fixes_applied: List[Dict[str, Any]] = field(default_factory=list)
    current_step: int = 0
    config: Dict[str, Any] = field(default_factory=dict)
    log: List[Dict[str, Any]] = field(default_factory=list)


@dataclass
class ToolMenuItem:
    """Menu item for the consolidated tool menu."""
    id: str
    tool_id: str
    display_name: str
    category: str
    command: str
    arguments: List[Dict[str, Any]] = field(default_factory=list)
    shortcut: str = ""
    icon: str = ""
    enabled: bool = True
    order: int = 100


@dataclass
class ConsolidatedToolMenu:
    """Consolidated menu for all tools."""
    menu_id: str
    created_at: str
    version: str
    tools: List[ToolMenuItem] = field(default_factory=list)
    categories: List[Dict[str, Any]] = field(default_factory=list)
    shortcuts: Dict[str, str] = field(default_factory=dict)
    config: Dict[str, Any] = field(default_factory=dict)


# =============================================================================
# TOOL DISCOVERY & PARSING
# =============================================================================

class ToolDiscoverer:
    """Discovers and parses tools in a directory."""
    
    def __init__(self, base_dir: Path):
        self.base_dir = base_dir.resolve()
        self.tools_dir = base_dir / "org_tools"
        self.tools_dir.mkdir(exist_ok=True)
        
        # Known tool patterns
        self.tool_patterns = {
            "analyzer": ["analyzer.py", "code_analyzer.py", "analysis_tool.py"],
            "organizer": ["organizer.py", "project_organizer.py"],
            "pathfixer": ["pathfixer.py", "path_fixer.py"],
            "import_organizer": ["import_organizer.py", "import_org.py"],
        }
        
        # Known tool categories
        self.known_tools = {
            "analyzer.py": ToolCategory.ANALYZER,
            "organizer.py": ToolCategory.ORGANIZER,
            "pathfixer.py": ToolCategory.PATHFIXER,
            "import_organizer.py": ToolCategory.IMPORT_ORG,
        }
        
    def discover_tools(self, recursive: bool = True, max_depth: int = 3) -> List[ToolMetadata]:
        """Discover tools in the directory."""
        logger.info(f"[EVENT] Discovering tools in {self.base_dir}")
        
        tools = []
        
        # First, check for known tools
        for tool_file, category in self.known_tools.items():
            tool_path = self.base_dir / tool_file
            if tool_path.exists():
                tool_meta = self._parse_tool(tool_path, category)
                if tool_meta:
                    tools.append(tool_meta)
                    logger.info(f"[EVENT] Found known tool: {tool_meta.name}")
        
        # Scan for other Python tools
        search_pattern = "**/*.py" if recursive else "*.py"
        
        for py_file in self.base_dir.glob(search_pattern):
            # Skip already processed files and __pycache__
            if py_file.name in self.known_tools or "__pycache__" in str(py_file):
                continue
            
            # Check if it looks like a tool (has argparse, main function, etc.)
            if self._looks_like_tool(py_file):
                category = self._categorize_tool(py_file)
                tool_meta = self._parse_tool(py_file, category)
                if tool_meta:
                    tools.append(tool_meta)
                    logger.info(f"[EVENT] Discovered tool: {tool_meta.name}")
        
        return tools
    
    def _looks_like_tool(self, file_path: Path) -> bool:
        """Check if a file looks like a CLI tool."""
        try:
            content = file_path.read_text(encoding='utf-8', errors='ignore')
            
            # Heuristics for tool detection
            checks = [
                "argparse.ArgumentParser" in content,
                "def main()" in content and "__name__ == '__main__'" in content,
                "sys.argv" in content,
                "click" in content,  # Click framework
                "fire" in content,   # Google Fire
                "typer" in content,  # Typer
            ]
            
            return any(checks)
        except:
            return False
    
    def _categorize_tool(self, file_path: Path) -> ToolCategory:
        """Categorize a tool based on filename and content."""
        name_lower = file_path.name.lower()
        
        # Check filename patterns
        if any(pattern in name_lower for pattern in ["analyzer", "analysis", "scan"]):
            return ToolCategory.ANALYZER
        elif any(pattern in name_lower for pattern in ["organizer", "organize", "manager"]):
            return ToolCategory.ORGANIZER
        elif any(pattern in name_lower for pattern in ["fixer", "fix", "repair"]):
            return ToolCategory.PATHFIXER
        elif any(pattern in name_lower for pattern in ["import", "dependency"]):
            return ToolCategory.IMPORT_ORG
        else:
            return ToolCategory.UTILITY
    
    def _parse_tool(self, file_path: Path, category: ToolCategory) -> Optional[ToolMetadata]:
        """Parse a tool file to extract metadata."""
        try:
            content = file_path.read_text(encoding='utf-8', errors='ignore')
            
            # Generate tool ID
            file_hash = hashlib.md5(str(file_path).encode()).hexdigest()[:12]
            tool_id = f"{category.value}_{file_hash}"
            
            # Extract name from file
            tool_name = file_path.stem.replace("_", " ").title()
            
            # Parse with AST
            tree = ast.parse(content)
            
            # Extract information
            has_argparse = self._detect_argparse(tree)
            has_tkinter = self._detect_tkinter(tree)
            description = self._extract_description(content)
            dependencies = self._extract_dependencies(tree)
            emitters = self._extract_emitters(content)
            
            # Extract argparse structure if present
            main_command, subcommands, global_args = None, [], []
            if has_argparse:
                arg_info = self._extract_argparse_info(content)
                main_command = arg_info.get("main")
                subcommands = arg_info.get("subcommands", [])
                global_args = arg_info.get("global_args", [])
            
            # Extract usage examples
            usage_examples = self._extract_usage_examples(content)
            
            return ToolMetadata(
                tool_id=tool_id,
                name=tool_name,
                file_path=file_path,
                category=category,
                description=description,
                has_argparse=has_argparse,
                has_tkinter=has_tkinter,
                main_command=main_command,
                subcommands=subcommands,
                global_arguments=global_args,
                dependencies=dependencies,
                usage_examples=usage_examples,
                emitters=emitters,
                tags=self._generate_tags(file_path, content, category)
            )
            
        except Exception as e:
            logger.error(f"[EVENT] Failed to parse tool {file_path}: {e}")
            return None
    
    def _detect_argparse(self, tree: ast.AST) -> bool:
        """Detect if argparse is used."""
        class ArgParseDetector(ast.NodeVisitor):
            def __init__(self):
                self.found = False
            
            def visit_Import(self, node):
                for alias in node.names:
                    if alias.name == 'argparse':
                        self.found = True
                self.generic_visit(node)
            
            def visit_ImportFrom(self, node):
                if node.module == 'argparse':
                    self.found = True
                self.generic_visit(node)
        
        detector = ArgParseDetector()
        detector.visit(tree)
        return detector.found
    
    def _detect_tkinter(self, tree: ast.AST) -> bool:
        """Detect if tkinter is used."""
        class TkinterDetector(ast.NodeVisitor):
            def __init__(self):
                self.found = False
            
            def visit_Import(self, node):
                for alias in node.names:
                    if alias.name in ['tkinter', 'Tkinter', 'Tk']:
                        self.found = True
                self.generic_visit(node)
            
            def visit_ImportFrom(self, node):
                if node.module and any(tk in node.module for tk in ['tkinter', 'Tkinter']):
                    self.found = True
                self.generic_visit(node)
            
            def visit_Call(self, node):
                if isinstance(node.func, ast.Name):
                    if node.func.id in ['Tk', 'Toplevel', 'Frame', 'Button']:
                        self.found = True
                self.generic_visit(node)
        
        detector = TkinterDetector()
        detector.visit(tree)
        return detector.found
    
    def _extract_description(self, content: str) -> str:
        """Extract description from docstring or comments."""
        # Try to get module docstring
        try:
            tree = ast.parse(content)
            docstring = ast.get_docstring(tree)
            if docstring:
                # Take first paragraph
                lines = docstring.strip().split('\n')
                first_para = []
                for line in lines:
                    line = line.strip()
                    if not line:
                        break
                    first_para.append(line)
                return ' '.join(first_para)[:200]  # Limit length
        except:
            pass
        
        # Look for description in argparse
        desc_match = re.search(r'description=["\']([^"\']+)["\']', content)
        if desc_match:
            return desc_match.group(1)[:200]
        
        # Look for file header comment
        lines = content.split('\n')
        header_comments = []
        for line in lines[:20]:  # Check first 20 lines
            if line.strip().startswith('#'):
                comment = line.strip('# ').strip()
                if comment and not comment.startswith('!'):  # Skip shebang
                    header_comments.append(comment)
        
        if header_comments:
            return ' '.join(header_comments[:3])[:200]
        
        return "No description available"
    
    def _extract_dependencies(self, tree: ast.AST) -> List[str]:
        """Extract imported modules as dependencies."""
        class ImportVisitor(ast.NodeVisitor):
            def __init__(self):
                self.imports = []
            
            def visit_Import(self, node):
                for alias in node.names:
                    self.imports.append(alias.name)
                self.generic_visit(node)
            
            def visit_ImportFrom(self, node):
                if node.module:
                    self.imports.append(node.module)
                self.generic_visit(node)
        
        visitor = ImportVisitor()
        visitor.visit(tree)
        
        # Filter out stdlib and common modules
        stdlib_modules = ['os', 'sys', 'json', 'argparse', 'datetime', 'pathlib', 
                         'typing', 're', 'logging', 'subprocess', 'shutil', 'tempfile']
        
        return [imp for imp in visitor.imports 
                if imp not in stdlib_modules and not imp.startswith('_')]
    
    def _extract_emitters(self, content: str) -> List[str]:
        """Extract data fields that this tool emits."""
        emitters = []
        
        # Look for common output patterns
        patterns = [
            r'output["\']?\s*:\s*["\']([^"\']+)["\']',
            r'emit["\']?\s*:\s*["\']([^"\']+)["\']',
            r'export["\']?\s*:\s*["\']([^"\']+)["\']',
            r'write.*json.*["\']([^"\']+)["\']',
            r'write.*csv.*["\']([^"\']+)["\']',
            r'manifest.*["\']([^"\']+)["\']',
            r'snapshot.*["\']([^"\']+)["\']',
        ]
        
        for pattern in patterns:
            matches = re.finditer(pattern, content, re.IGNORECASE)
            for match in matches:
                emitter = match.group(1)
                if emitter and emitter not in emitters:
                    emitters.append(emitter)
        
        return emitters
    
    def _extract_argparse_info(self, content: str) -> Dict[str, Any]:
        """Extract argparse structure from content."""
        # This is a simplified parser - in reality would need full AST parsing
        # or actually running the script with --help
        
        main_command = None
        subcommands = []
        global_args = []
        
        # Look for ArgumentParser creation
        parser_match = re.search(r'ArgumentParser\([^)]*description=["\']([^"\']+)["\'][^)]*\)', content)
        if parser_match:
            main_command = ArgParseCommand(
                name="main",
                help_text=parser_match.group(1)
            )
        
        # Look for add_argument calls
        arg_pattern = r'add_argument\([^)]*\)'
        arg_matches = re.finditer(arg_pattern, content)
        
        for match in arg_matches:
            arg_text = match.group(0)
            
            # Extract argument name
            name_match = re.search(r'["\']([^"\']+)["\']', arg_text)
            if name_match:
                arg_name = name_match.group(1)
                
                # Determine type
                if arg_name.startswith('-'):
                    arg_type = ArgParseType.OPTIONAL
                else:
                    arg_type = ArgParseType.POSITIONAL
                
                # Extract help
                help_match = re.search(r'help=["\']([^"\']+)["\']', arg_text)
                help_text = help_match.group(1) if help_match else ""
                
                arg = ArgParseArgument(
                    name=arg_name,
                    arg_type=arg_type,
                    help_text=help_text
                )
                
                if arg_type == ArgParseType.POSITIONAL:
                    if main_command:
                        main_command.arguments.append(arg)
                else:
                    global_args.append(arg)
        
        # Look for subparsers
        subparser_pattern = r'add_subparsers\([^)]*\)'
        if re.search(subparser_pattern, content):
            # Find subcommand patterns (simplified)
            # In reality, would need to parse the subparser.add_parser calls
            
            # For now, add placeholder subcommands
            subcommands = [
                ArgParseCommand(name="subcommand1", help_text="First subcommand"),
                ArgParseCommand(name="subcommand2", help_text="Second subcommand"),
            ]
        
        return {
            "main": main_command,
            "subcommands": subcommands,
            "global_args": global_args
        }
    
    def _extract_usage_examples(self, content: str) -> List[str]:
        """Extract usage examples from comments or docstring."""
        examples = []
        
        # Look for example patterns
        example_patterns = [
            r'# Examples?:?\s*\n(?:#\s+.*\n)+',
            r'"""Examples?:?\s*\n(?:.*\n)+?"""',
            r"'''Examples?:?\s*\n(?:.*\n)+?'''",
            r'# Usage?:?\s*\n(?:#\s+.*\n)+',
        ]
        
        for pattern in example_patterns:
            matches = re.finditer(pattern, content, re.IGNORECASE | re.MULTILINE)
            for match in matches:
                example_block = match.group(0)
                # Clean up the block
                lines = example_block.split('\n')
                for line in lines:
                    line = line.strip()
                    if line.startswith('#') or line.startswith('"""') or line.startswith("'''"):
                        line = line.lstrip('#\'" ').strip()
                    if line and 'example' not in line.lower() and 'usage' not in line.lower():
                        examples.append(line[:100])  # Limit length
        
        return examples[:5]  # Return first 5 examples
    
    def _generate_tags(self, file_path: Path, content: str, category: ToolCategory) -> List[str]:
        """Generate tags for the tool."""
        tags = [category.value]
        
        # Content-based tags
        content_lower = content.lower()
        
        if 'tkinter' in content_lower:
            tags.append('gui')
        if 'argparse' in content_lower:
            tags.append('cli')
        if 'json' in content_lower:
            tags.append('json')
        if 'diff' in content_lower:
            tags.append('diff')
        if 'patch' in content_lower:
            tags.append('patch')
        if 'scan' in content_lower:
            tags.append('scanner')
        if 'fix' in content_lower:
            tags.append('fixer')
        if 'organize' in content_lower:
            tags.append('organizer')
        
        # Filename-based tags
        name_lower = file_path.name.lower()
        if 'tool' in name_lower:
            tags.append('tool')
        if 'util' in name_lower:
            tags.append('utility')
        if 'helper' in name_lower:
            tags.append('helper')
        
        return list(set(tags))  # Remove duplicates


# =============================================================================
# TOOL CONSOLIDATION & MENU BUILDER
# =============================================================================

class ToolConsolidator:
    """Consolidates multiple tools into a unified interface."""
    
    def __init__(self, tools_dir: Path):
        self.tools_dir = tools_dir
        self.menu_file = tools_dir / "consolidated_menu.json"
        self.launcher_file = tools_dir / "launcher.py"
        
    def consolidate_tools(self, tools: List[ToolMetadata], 
                         menu_name: str = "Org Tools") -> ConsolidatedToolMenu:
        """Consolidate tools into a unified menu."""
        logger.info(f"[EVENT] Consolidating {len(tools)} tools")
        
        # Create menu items from tools
        menu_items = []
        category_map = {}
        
        for i, tool in enumerate(tools):
            # Create menu item
            menu_item = self._create_menu_item(tool, i)
            menu_items.append(menu_item)
            
            # Track categories
            category = tool.category.value
            if category not in category_map:
                category_map[category] = {
                    "name": category,
                    "display_name": category.title(),
                    "count": 0,
                    "tools": []
                }
            category_map[category]["count"] += 1
            category_map[category]["tools"].append(menu_item.id)
        
        # Create categories list
        categories = list(category_map.values())
        categories.sort(key=lambda x: x["count"], reverse=True)
        
        # Create shortcuts
        shortcuts = {}
        for item in menu_items:
            if item.order <= 26:  # A-Z
                shortcuts[chr(64 + item.order)] = item.id
        
        # Create consolidated menu
        menu = ConsolidatedToolMenu(
            menu_id=f"menu_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}",
            created_at=datetime.datetime.now().isoformat(),
            version="1.0.0",
            tools=menu_items,
            categories=categories,
            shortcuts=shortcuts,
            config={
                "name": menu_name,
                "auto_refresh": True,
                "show_icons": True,
                "group_by_category": True,
                "enable_shortcuts": True,
                "max_recent_tools": 10,
            }
        )
        
        # Save menu
        self._save_menu(menu)
        
        # Generate launcher
        self._generate_launcher(menu)
        
        logger.info(f"[EVENT] Created consolidated menu with {len(menu_items)} items")
        return menu
    
    def _create_menu_item(self, tool: ToolMetadata, index: int) -> ToolMenuItem:
        """Create a menu item from tool metadata."""
        # Determine command
        if tool.has_argparse and tool.main_command:
            # Use the first subcommand or main command
            if tool.subcommands:
                command = f"{tool.name.lower()}_{tool.subcommands[0].name}"
            else:
                command = tool.name.lower().replace(" ", "_")
        else:
            command = tool.name.lower().replace(" ", "_")
        
        # Determine display name
        display_name = tool.name
        
        # Create arguments structure
        arguments = []
        if tool.global_arguments:
            for arg in tool.global_arguments[:5]:  # Limit to 5 args
                arguments.append({
                    "name": arg.name,
                    "type": arg.arg_type.value,
                    "help": arg.help_text,
                    "required": arg.required
                })
        
        # Assign shortcut based on order
        shortcut = ""
        if index < 26:  # A-Z
            shortcut = chr(65 + index)  # A=65
        
        return ToolMenuItem(
            id=f"tool_{tool.tool_id}",
            tool_id=tool.tool_id,
            display_name=display_name,
            category=tool.category.value,
            command=command,
            arguments=arguments,
            shortcut=shortcut,
            icon=self._get_icon_for_category(tool.category),
            order=index + 1
        )
    
    def _get_icon_for_category(self, category: ToolCategory) -> str:
        """Get icon for tool category."""
        icons = {
            ToolCategory.ANALYZER: "📊",
            ToolCategory.ORGANIZER: "🗂️",
            ToolCategory.PATHFIXER: "🔧",
            ToolCategory.IMPORT_ORG: "📦",
            ToolCategory.UTILITY: "🛠️",
            ToolCategory.CUSTOM: "🌟",
        }
        return icons.get(category, "📄")
    
    def _save_menu(self, menu: ConsolidatedToolMenu):
        """Save menu to JSON file."""
        menu_data = asdict(menu)
        
        with open(self.menu_file, 'w', encoding='utf-8') as f:
            json.dump(menu_data, f, indent=2, default=str)
        
        logger.info(f"[EVENT] Menu saved to {self.menu_file}")
    
    def _generate_launcher(self, menu: ConsolidatedToolMenu):
        """Generate a Python launcher script for the menu."""
        launcher_content = f'''#!/usr/bin/env python3
"""
Consolidated Tool Launcher
==========================
Generated: {datetime.datetime.now().isoformat()}
Version: {menu.version}

Launch tool: {menu.config.get('name', 'Org Tools')}
"""

import os
import sys
import json
import argparse
import subprocess
import tkinter as tk
from pathlib import Path
from typing import Dict, List, Any

# Load menu configuration
MENU_FILE = Path(__file__).parent / "consolidated_menu.json"

def load_menu() -> Dict[str, Any]:
    """Load the menu configuration."""
    with open(MENU_FILE, 'r') as f:
        return json.load(f)

def list_tools(menu_data: Dict[str, Any]):
    """List all available tools."""
    print(f"\\n{{'='*60}}")
    print(f"{{menu_data['config'].get('name', 'Available Tools')}}")
    print(f"{{'='*60}}")

    categories = {{}}
    for tool in menu_data['tools']:
        category = tool['category']
        if category not in categories:
            categories[category] = []
        categories[category].append(tool)

    for category, tools in categories.items():
        print(f"\\n{{category.upper()}}:")
        for tool in tools:
            shortcut = tool.get('shortcut', '')
            shortcut_display = f" [{{shortcut}}]" if shortcut else ""
            print(f"  {{tool['display_name']}}{{shortcut_display}}")
            if tool.get('description'):
                print(f"    {{tool['description']}}")

def launch_tool(tool_id: str, menu_data: Dict[str, Any], args: List[str] = None):
    """Launch a specific tool."""
    for tool in menu_data['tools']:
        if tool['id'] == tool_id or tool['tool_id'] == tool_id:
            print(f"Launching: {{tool['display_name']}}")
            # In a real implementation, this would execute the actual tool
            # For now, just show what would happen
            print(f"Tool ID: {{tool['tool_id']}}")
            print(f"Command: {{tool['command']}}")
            if args:
                print(f"Arguments: {{' '.join(args)}}")
            return True
    
    print(f"Tool not found: {{tool_id}}")
    return False

def launch_gui(menu_data: Dict[str, Any]):
    """Launch GUI version of the menu."""
    try:
        from tkinter import Tk, ttk, messagebox
        import tkinter as tk
        
        class ToolLauncherGUI:
            def __init__(self, menu_data: Dict[str, Any]):
                self.menu_data = menu_data
                self.root = Tk()
                self.root.title(menu_data['config'].get('name', 'Tool Launcher'))
                self.root.geometry("800x600")
                
                self.setup_ui()
            
            def setup_ui(self):
                # Create notebook for categories
                notebook = ttk.Notebook(self.root)
                notebook.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
                
                # Group tools by category
                categories = {{}}
                for tool in self.menu_data['tools']:
                    category = tool['category']
                    if category not in categories:
                        categories[category] = []
                    categories[category].append(tool)
                
                # Create tab for each category
                for category, tools in categories.items():
                    frame = ttk.Frame(notebook)
                    notebook.add(frame, text=category.title())
                    
                    # Create listbox for tools
                    listbox = tk.Listbox(frame, font=("Courier", 12))
                    scrollbar = ttk.Scrollbar(frame, orient=tk.VERTICAL, command=listbox.yview)
                    listbox.configure(yscrollcommand=scrollbar.set)
                    
                    for tool in tools:
                        shortcut = tool.get('shortcut', '')
                        shortcut_display = f" [{{shortcut}}]" if shortcut else ""
                        listbox.insert(tk.END, f"{{tool['display_name']}}{{shortcut_display}}")
                    
                    listbox.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5, pady=5)
                    scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
                    
                    # Bind double-click
                    listbox.bind('<Double-Button-1>', lambda e, t=tools: self.on_tool_selected(t, listbox.curselection()))
                
                # Add status bar
                status_frame = ttk.Frame(self.root)
                status_frame.pack(fill=tk.X, padx=5, pady=2)
                
                ttk.Label(status_frame, 
                         text=f"{{len(self.menu_data['tools'])}} tools available").pack(side=tk.LEFT)
                
                ttk.Button(self.root, text="Refresh", command=self.refresh).pack(pady=5)
                ttk.Button(self.root, text="Exit", command=self.root.quit).pack(pady=5)
            
            def on_tool_selected(self, tools, selection):
                if selection:
                    index = selection[0]
                    if 0 <= index < len(tools):
                        tool = tools[index]
                        messagebox.showinfo("Tool Selected", 
                                          f"Selected: {{tool['display_name']}}\\n\\n"
                                          f"To launch from CLI:\\n"
                                          f"  python launcher.py --tool {{tool['id']}}")
            
            def refresh(self):
                messagebox.showinfo("Refresh", "Menu would be refreshed from disk")
            
            def run(self):
                self.root.mainloop()
        
        gui = ToolLauncherGUI(menu_data)
        gui.run()
        
    except ImportError as e:
        print(f"GUI not available: {{e}}")
        list_tools(menu_data)

def main():
    parser = argparse.ArgumentParser(
        description='Consolidated Tool Launcher',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Examples:
  # List all tools
  {Path(__file__).name} --list

  # Launch specific tool
  {Path(__file__).name} --tool TOOL_ID [-- ARGS...]

  # Launch GUI
  {Path(__file__).name} --gui

  # Get help for a tool
  {Path(__file__).name} --help-tool TOOL_ID
        """
    )
    
    parser.add_argument('--list', '-l', action='store_true', help='List all available tools')
    parser.add_argument('--tool', '-t', help='Launch specific tool by ID or name')
    parser.add_argument('--gui', '-g', action='store_true', help='Launch GUI interface')
    parser.add_argument('--help-tool', help='Show help for a specific tool')
    parser.add_argument('args', nargs='*', help='Arguments to pass to the tool')
    
    args = parser.parse_args()
    
    # Load menu data
    try:
        menu_data = load_menu()
    except Exception as e:
        print(f"Error loading menu: {{e}}")
        return 1
    
    if args.list:
        list_tools(menu_data)
    
    elif args.tool:
        launch_tool(args.tool, menu_data, args.args)
    
    elif args.gui:
        launch_gui(menu_data)
    
    elif args.help_tool:
        print(f"Help for tool {{args.help_tool}} would be displayed here")
        # In reality, would show the tool's --help output
    
    else:
        parser.print_help()
        print(f"\\nUse --list to see available tools")

if __name__ == '__main__':
    main()
